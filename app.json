{
  "expo": {
    "name": "Voice Record Customer Honda",
    "slug": "voice-record-customer-honda",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "voicerecordcustomerhonda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capelladinamiknusantara.audioarchiver",
      "buildNumber": "3",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Rekam suara konsumen untuk dokumentasi servis"
      }
    },
    "android": {
      "package": "com.capelladinamiknusantara.audioarchiver",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Rekam suara konsumen untuk dokumentasi servis"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Izinkan akses kamera untuk foto CDB",
          "cameraPermission": "Izinkan akses kamera untuk foto CDB"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
