{
  "expo": {
    "name": "HAVOC",
    "slug": "voice-record-customer-honda",
    "version": "3.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "voicerecordcustomerhonda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash_light.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF",
      "dark": {
        "image": "./assets/images/splash_dark.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capelladinamiknusantara.audioarchiver",
      "buildNumber": "3",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Rekam suara konsumen untuk dokumentasi servis"
      },
      "splash": {
        "image": "./assets/images/splash_light.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF",
        "tabletImage": "./assets/images/splash_light.png",
        "dark": {
          "image": "./assets/images/splash_dark.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "tabletImage": "./assets/images/splash_dark.png"
        }
      }
    },
    "android": {
      "package": "com.capelladinamiknusantara.audioarchiver",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#e02010"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "edgeToEdgeEnabled": true,
      "splash": {
        "image": "./assets/images/splash_light.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF",
        "mdpi":    "./assets/images/splash_light.png",
        "hdpi":    "./assets/images/splash_light.png",
        "xhdpi":   "./assets/images/splash_light.png",
        "xxhdpi":  "./assets/images/splash_light.png",
        "xxxhdpi": "./assets/images/splash_light.png",
        "dark": {
          "image": "./assets/images/splash_dark.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "mdpi":    "./assets/images/splash_dark.png",
          "hdpi":    "./assets/images/splash_dark.png",
          "xhdpi":   "./assets/images/splash_dark.png",
          "xxhdpi":  "./assets/images/splash_dark.png",
          "xxxhdpi": "./assets/images/splash_dark.png"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-system-ui",
        {
          "backgroundColor": "#09090B"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Rekam suara konsumen untuk dokumentasi servis"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Izinkan akses kamera untuk foto CDB",
          "cameraPermission": "Izinkan akses kamera untuk foto CDB"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "aaf622f0-9bc1-47a5-b3fe-78799ebf4825"
      },
      "router": {}
    }
  }
}
